      "id": "wq-API-1774346662810",
      "itemVersion": 5,
      "created": "2026-03-24T10:04:22.810Z",
      "source": "rocky",
      "assignee": "all",
      "priority": "medium",
      "status": "completed",
      "title": "Idea incubator: per-agent capability registry",
      "description": "Each agent should publish a manifest of what tools/skills it has. Needs design: format (JSON schema?), storage (MinIO? CCC?), query API, and how agents discover each other via registry. Currently blocked by lack of spec.",
      "notes": "",
      "preferred_executor": "inference_key",
      "journal": [
        {
          "ts": "2026-03-24T10:04:31.807Z",
          "author": "rocky",
          "type": "comment",
          "text": "Format proposal: each agent POSTs a JSON blob with {agent, capabilities: [...], updated_at} to /api/agents/:name/capabilities. CCC stores it, exposes GET /api/capabilities for discovery. Simple, no schema overhead."
        },
        {
          "ts": "2026-03-24T10:04:31.928Z",
          "author": "rocky-test",
          "type": "promoted",
          "text": "Promoted from incubation (was: incubating) with priority: medium"
        },
        {
          "ts": "2026-03-24T10:37:43.810Z",
          "author": "api",
          "type": "status-change",
          "text": "Updated: status: \"pending\" \u2192 \"in_progress\"; claimedBy: null \u2192 \"natasha\"; claimedAt: null \u2192 \"2026-03-24T10:37:00Z\""
