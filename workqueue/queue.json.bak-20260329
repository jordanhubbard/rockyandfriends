    {
      "id": "wq-API-1774699545633",
      "itemVersion": 3,
      "created": "2026-03-28T12:05:45.633Z",
      "source": "api",
      "assignee": "rocky",
      "priority": "idea",
      "status": "completed",
      "title": "CCC cron prompts: embed correct RCC_AGENT_TOKEN env var reference instead of hardcoded token placeholder",
      "description": "Workqueue agent cron prompts reference wq-dash-token-2026 as the bearer token for API calls, but the actual auth token lives in ~/.rcc/.env as RCC_AGENT_TOKEN. Every cron cycle wastes time re-discovering the right token. Cron prompt should reference $RCC_AGENT_TOKEN or document that wq-dash-token-2026 is a display-only token, not the API auth token.",
      "notes": "",
      "preferred_executor": "claude_cli",
