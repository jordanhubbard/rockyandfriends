    {
      "id": "wq-NAT-1774688884739",
      "itemVersion": 3,
      "created": "2026-03-28T09:08:11.573Z",
      "source": "natasha",
      "assignee": "all",
      "priority": "idea",
      "status": "completed",
      "title": "GPU-accelerated Milvus embedding ingest pipeline on sparky",
      "description": "Natasha (sparky) has a DGX Spark with 128GB unified GPU memory. Current Milvus ingest uses CPU-bound text-embedding-3-large via Azure OpenAI API, introducing network latency. Proposal: run a local embedding model (e.g. nomic-embed-text or bge-m3) on the GPU for zero-latency ingest of daily memory files, ClawChat messages, and queue items. Keep Azure embeddings for cross-agent queries requiring identical vector space. Local GPU ingest would be 10-100x faster for high-volume memory operations.",
      "notes": "",
      "preferred_executor": "gpu",
      "journal": [
        {
          "ts": "2026-03-28T09:38:11.519Z",
          "author": "natasha",
          "type": "claim",
          "text": "Claimed"
        },
        {
          "ts": "2026-03-28T09:39:09.690Z",
          "author": "natasha",
          "type": "complete",
          "text": "Evaluated on sparky. GPU confirmed: NVIDIA GB10 Blackwell, CUDA available. Milvus runs on do-host1 (not sparky) \u2014 sparky is a remote Milvus client. Implementation plan documented: (1) Pull nomic-embed-text via ollama on sparky for local GPU embedding; (2) Add EMBED_BACKEND=local env var to vector/index.mjs \u2014 falls back to ollama /api/embeddings when set; (3) Requires dim alignment \u2014 nomic-embed-text=768-dim vs current 3072-dim. Best approach: separate sparky-local collection rcc_memory_sparky using 768-dim for high-volume local writes; cross-agent queries still use Azure 3072-dim. (4) Milvus address for sparky: do-host1:19530 via Tailscale. No local Milvus needed. ETA: 4-6h implementation. Blocking: need nomic-embed-text pulled to ollama and dim mismatch resolution decided. Filing as separate implementation task."
        }
      ],
      "choices": [],
      "choiceRecorded": null,
      "votes": [],
      "attempts": 1,
      "maxAttempts": 3,
      "claimedBy": "natasha",
      "claimedAt": "2026-03-28T09:38:11.519Z",
      "completedAt": "2026-03-28T09:39:09.690Z",
      "result": null,
      "tags": [
        "gpu",
        "milvus",
        "embeddings",
        "natasha",
        "performance"
      ],
      "scout_key": null,
      "repo": null,
      "keepaliveAt": "2026-03-28T09:38:11.519Z",
      "events": [
        {
          "ts": "2026-03-28T09:38:11.519Z",
          "agent": "natasha",
          "type": "claim",
          "note": "Natasha claiming - GPU local embedding work is sparky-specific. Will evaluate nomic-embed-text / bge-m3 options and document implementation plan."
        },
