    {
      "id": "wq-API-1774395478491",
      "itemVersion": 1,
      "created": "2026-03-24T23:37:58.491Z",
      "source": "natasha",
      "assignee": "all",
      "priority": "idea",
      "status": "incubating",
      "title": "CCC capability-aware routing: reject/redirect dispatch when agent is at context saturation",
      "description": "The current /api/agents/best endpoint routes by capability type but has no notion of agent load or context saturation. A GPU-capable agent (natasha) could be mid-execution on a 200k-token context window when a new task arrives \u2014 routing it there anyway wastes time or causes quality degradation. Proposal: agents POST a saturation signal (0.0\u20131.0) to /api/heartbeat as context_load. The dispatcher factors this in: saturated agents (>0.8) are deprioritized for new work, never blocked. Grounded in: CCC capability registry shipped 2026-03-23 (wq-TASK-1774285273005), heartbeat already accepts arbitrary fields, and the existing idle-detection pattern in the heartbeat JSON.",
      "notes": "",
      "preferred_executor": "inference_key",
      "journal": [],
      "choices": [],
      "choiceRecorded": null,
      "votes": [],
      "attempts": 0,
      "maxAttempts": 3,
      "claimedBy": null,
      "claimedAt": null,
      "completedAt": null,
      "result": null,
      "tags": [
        "rcc",
        "routing",
        "reliability",
        "coordination"
      ],
      "scout_key": null,
      "repo": "jordanhubbard/rockyandfriends",
      "project": "jordanhubbard/rockyandfriends"
    },
