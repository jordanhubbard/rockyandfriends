      "id": "wq-API-1774435149031",
      "itemVersion": 1,
      "created": "2026-03-25T10:39:09.031Z",
      "source": "natasha:idea",
      "assignee": "all",
      "priority": "idea",
      "status": "incubating",
      "title": "usdagent: Add batch export mode for processing multiple USD files in a single CLI invocation",
      "description": "Currently usdagent processes one USD file at a time. A batch mode (--batch dir/ or --batch file1 file2...) would allow bulk exports to Google Drive or local output without repeated CLI invocations. Useful for scenes with many assets or CI export pipelines.",
