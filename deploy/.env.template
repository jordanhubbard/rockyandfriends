# RCC Agent Node — Environment Template
# Copy this to .env and fill in values. NEVER commit .env to git.
#
# Quickest path: run deploy/rcc-init.sh — it fills this in interactively.
# Manual:        cp deploy/.env.template ~/.rcc/.env && nano ~/.rcc/.env

# ── RCC Connection ─────────────────────────────────────────────────────────
# URL of the RCC API (e.g. https://rcc.yourdomain.com or http://192.168.1.10:8789)
RCC_URL=
# Bearer token for this agent (issued by RCC admin after registration)
RCC_AGENT_TOKEN=

# ── Agent Identity ─────────────────────────────────────────────────────────
# Short unique name for this agent (e.g. myagent, builder, gpu-box)
AGENT_NAME=
# Human-readable hostname for display in dashboard
AGENT_HOST=

# ── Agent Capabilities (declare what this node can do) ───────────────────
# Does this node have a Claude CLI session running in tmux? (true/false)
AGENT_CLAUDE_CLI=false
# Which Claude model? (e.g. claude-sonnet-4-6)
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
# Does this node have GPU(s)? (true/false)
AGENT_HAS_GPU=false
# GPU model string (e.g. "L40", "H100", "RTX 4090", "Blackwell B200")
AGENT_GPU_MODEL=
# Number of GPUs
AGENT_GPU_COUNT=0
# Total GPU VRAM in GB
AGENT_GPU_VRAM_GB=0

# ── NVIDIA Inference ───────────────────────────────────────────────────────
# NVIDIA inference gateway (standard endpoint)
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
# API key from NVIDIA portal (rate-limited but real LLM access)
NVIDIA_API_KEY=

# ── Storage: MinIO (internal fast storage) ────────────────────────────────
# Internal S3-compatible endpoint (Tailscale or private network only)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Bucket name (agents is the standard shared bucket)
MINIO_BUCKET=agents

# ── Storage: Azure Blob (public assets) ───────────────────────────────────
# Public read URL base (no auth needed to read)
AZURE_BLOB_PUBLIC_URL=
# SAS token URL for writes (expires — rotate periodically)
# Full URL pattern: ${AZURE_BLOB_PUBLIC_URL}/<filename>?<sas_token>
AZURE_BLOB_SAS_TOKEN=

# ── Channel Integrations (optional — set what this node uses) ─────────────
# Slack bot token (xoxb-...)
SLACK_TOKEN=
# Mattermost personal access token
MATTERMOST_TOKEN=
MATTERMOST_URL=
# Telegram bot token
TELEGRAM_TOKEN=

# ── RCC API (only needed if THIS node is running the RCC API server) ───────
RCC_PORT=8789
# Comma-separated list of valid auth tokens (for RCC API server)
RCC_AUTH_TOKENS=
# Default triaging agent for repos with no explicit ownership set
DEFAULT_TRIAGING_AGENT=

# ── Workqueue API ──────────────────────────────────────────────────────────
# Bearer token for the local workqueue dashboard API (port 8787)
WQ_API_TOKEN=

# ── SquirrelBus peers (set for each peer this node fans out to) ────────────
# PEERNAME_BUS_URL=http://<peer-host>:18789/bus/receive
# PEERNAME_TOKEN=<peer-bearer-token>

# Slack workspace-specific vars (optional — add your own as needed)
# SLACK_MY_WORKSPACE_TOKEN=xoxb-...
# WATCH_CHANNEL=                   # channel ID for project watch notifications
