# ACC Agent — Environment Template
# Copy to ~/.acc/.env and fill in your values. NEVER commit .env to git.
#
#   cp deploy/.env.template ~/.acc/.env && nano ~/.acc/.env
#
# This file is for agent nodes connecting to an existing ACC hub.
# If you are standing up a new ACC hub, also see deploy/.env.server.template.
#
# ── SECURITY MODEL ─────────────────────────────────────────────────────────
# The only secret you provide at onboarding is ACC_AGENT_TOKEN.
# All other secrets (Slack, NVIDIA, MinIO, etc.) are stored in ACC and synced
# to this file by secrets-sync.sh on each agent-pull run.
# DO NOT manually populate channel or inference secrets below — let
# secrets-sync.sh manage them.

# ── ACC Hub Connection ────────────────────────────────────────────────────
# Provided by your ACC admin at onboarding.
ACC_URL=
ACC_AGENT_TOKEN=
# Legacy CCC_URL/CCC_AGENT_TOKEN are also accepted by acc-agent and acc-server
# during migration, but new nodes should write ACC_URL/ACC_AGENT_TOKEN.

# Optional: Tailscale URL for the hub. If set, acc-connectivity-check.sh
# will prefer this over the public IP when the current URL is unreachable.
ACC_TAILSCALE_URL=

# Optional: MinIO endpoint on the hub (for agentfs-sync and shared binaries).
ACC_MINIO_URL=

# ── Agent Identity ─────────────────────────────────────────────────────────
AGENT_NAME=
AGENT_HOST=

# ── Agent Capabilities ────────────────────────────────────────────────────
AGENT_CLAUDE_CLI=false
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
AGENT_HAS_GPU=false
AGENT_GPU_MODEL=
AGENT_GPU_COUNT=0
AGENT_GPU_VRAM_GB=0

# ── vLLM (local GPU model serving) ──────────────────────────────────────
# Only relevant on GPU nodes. Auto-detected by bootstrap/setup scripts.
VLLM_ENABLED=false
VLLM_MODEL=google/gemma-4-31B-it
VLLM_SERVED_NAME=gemma
VLLM_PORT=8000
VLLM_MODEL_PATH=
VLLM_EXTRA_ARGS=

# ── TokenHub ──────────────────────────────────────────────────────────────
# Local LLM routing proxy (OpenAI-compatible). Defaults to localhost.
TOKENHUB_URL=http://localhost:8090
TOKENHUB_API_KEY=
TOKENHUB_ADMIN_TOKEN=

# ── NVIDIA Inference ──────────────────────────────────────────────────────
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=
# Claude CLI uses the local proxy (strips anthropic-beta before forwarding to NVIDIA)
ANTHROPIC_BASE_URL=http://localhost:9099
ANTHROPIC_API_KEY=   # set to NVIDIA_API_KEY value
# Hermes agent model — must match a model available on OPENAI_BASE_URL
# For NVIDIA NIM: azure/anthropic/claude-sonnet-4-6
# For Anthropic direct: claude-opus-4-7
HERMES_MODEL=azure/anthropic/claude-sonnet-4-6
# OpenAI-compatible base URL (NVIDIA NIM)
OPENAI_BASE_URL=https://inference-api.nvidia.com/v1
OPENAI_API_KEY=   # set to NVIDIA_API_KEY value

# ── AgentBus ──────────────────────────────────────────────────────────────
# Shared secret for HMAC-signed exec payloads. If blank, exec signing falls
# back to ACC_AGENT_TOKEN for compatibility with older SquirrelBus deployments.
AGENTBUS_TOKEN=

# ── Qdrant Vector DB ──────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBED_MODEL=azure/openai/text-embedding-3-large
EMBED_DIM=3072

# ── Messaging ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
# Slack — uses Slack Bolt (Socket Mode). Both tokens required for Slack.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── GitHub Issue Sync ─────────────────────────────────────────────────────
# Optional hub/operator workflow. github_sync polls these repositories into
# beads and promotes issues with GITHUB_DISPATCH_LABEL to /api/tasks.
GITHUB_REPOS=
GITHUB_DISPATCH_LABEL=agent-ready
GITHUB_SYNC_INTERVAL=300
GITHUB_AUTO_CLOSE=false
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# ── Tailscale ─────────────────────────────────────────────────────────────
# Pre-auth key for unattended node registration (optional).
# Install scripts must run `tailscale set --accept-dns=false` before
# `tailscale up` so Tailscale does not replace host DNS.
TS_AUTHKEY=
