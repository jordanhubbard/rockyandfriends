# RCC Agent — Environment Template
# Copy to ~/.rcc/.env and fill in your values. NEVER commit .env to git.
#
#   cp deploy/.env.template ~/.rcc/.env && nano ~/.rcc/.env
#
# This file is for CLIENT AGENTS connecting to an existing RCC hub.
# If you are standing up a new RCC hub, also see deploy/.env.server.template.
#
# ── SECURITY MODEL ─────────────────────────────────────────────────────────
# The only secret you provide at onboarding is RCC_AGENT_TOKEN.
# All other secrets (Slack, Mattermost, NVIDIA, MinIO, etc.) are stored in
# RCC and synced to this file by secrets-sync.sh on each agent-pull run.
#
# DO NOT manually populate Slack/Mattermost/NVIDIA/MinIO secrets below.
# Let secrets-sync.sh manage them. The only exception: NVIDIA_API_KEY is
# permitted in .env as a fallback if RCC is temporarily unreachable.
# See: rcc/docs/security-model.md

# ── RCC Connection ─────────────────────────────────────────────────────────
# The URL and token for your RCC hub — provided by your RCC admin at onboarding
RCC_URL=
RCC_AGENT_TOKEN=

# ── Agent Identity ─────────────────────────────────────────────────────────
# Short name for this agent (e.g. bullwinkle, natasha, boris, or your own name)
AGENT_NAME=
# Human-readable hostname shown in the dashboard
AGENT_HOST=

# ── Agent Capabilities ────────────────────────────────────────────────────
# Declare what this node can do so the RCC hub can route work to you correctly
AGENT_CLAUDE_CLI=false
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
AGENT_HAS_GPU=false
AGENT_GPU_MODEL=
AGENT_GPU_COUNT=0
AGENT_GPU_VRAM_GB=0

# ── ClawFS (shared model/file cache via JuiceFS) ────────────────────────
# Auto-mounted on Linux, optional on macOS (requires macFUSE).
# Set CLAWFS_ENABLED=false to skip mounting even if JuiceFS is available.
CLAWFS_ENABLED=true
CLAWFS_MOUNT=$HOME/clawfs
CLAWFS_REDIS_URL=redis://100.89.199.14:6379/1
CLAWFS_CACHE_DIR=/tmp/jfscache

# ── vLLM (local GPU model serving) ──────────────────────────────────────
# Only relevant on GPU nodes. Auto-detected by bootstrap/setup scripts.
VLLM_ENABLED=false
VLLM_MODEL=google/gemma-4-31B-it
VLLM_SERVED_NAME=gemma
VLLM_PORT=8000
VLLM_MODEL_PATH=
# Set VLLM_EXTRA_ARGS for additional vLLM flags (e.g. --tensor-parallel-size 4)
VLLM_EXTRA_ARGS=

# ── TokenHub ──────────────────────────────────────────────────────────────
# TokenHub is the local LLM routing proxy (OpenAI-compatible) — preferred.
TOKENHUB_URL=http://100.89.199.14:8090
TOKENHUB_API_KEY=
TOKENHUB_ADMIN_TOKEN=                    # Vault admin token — enables self-service secret retrieval

# ── NVIDIA Inference ──────────────────────────────────────────────────────
# NVIDIA_API_KEY is now only needed as a fallback if TOKENHUB_API_KEY is not set.
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=

# ── ClawBus (agent-to-agent communication) ────────────────────────────────
# Shared secret for HMAC-signed exec payloads + bus authentication
CLAWBUS_TOKEN=
# ClawBus hub URL (default: http://localhost:8788)
CLAWBUS_URL=
# Deprecated aliases (still supported as fallbacks):
# SQUIRRELBUS_TOKEN=
# SQUIRRELBUS_URL=

# ── Qdrant Vector DB (for RAG / memory / search) ─────────────────────────
# Point at the fleet Qdrant instance on do-host1
QDRANT_URL=http://146.190.134.110:6333
QDRANT_API_KEY=
EMBED_MODEL=azure/openai/text-embedding-3-large
EMBED_DIM=3072

# ── Messaging ─────────────────────────────────────────────────────────────
# Mattermost: get a personal access token from your Mattermost instance
MATTERMOST_TOKEN=
MATTERMOST_URL=

# Telegram: optional direct bot channel
TELEGRAM_TOKEN=

# Slack: agents use the RCC hub as a proxy — no per-agent Slack app needed.
# To post to Slack, call: POST $RCC_URL/api/slack/send
#   {"text": "...", "channel": "C...", "as_agent": "yourname"}
# The hub posts on your behalf with your configured username/emoji.
# Leave SLACK_TOKEN blank unless you ARE the RCC hub.
SLACK_TOKEN=
# Signing secret from Slack App settings — required for inbound event verification.
# Get it from https://api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# ── Tailscale (mesh networking) ───────────────────────────────────────────────
# setup-container.sh detects container environments (supervisord PID 1,
# /.dockerenv, /run/.containerenv) and automatically uses userspace networking
# mode so Tailscale works without CAP_NET_ADMIN or a kernel TUN device.
#
# TS_LOGIN_SERVER: your Headscale or Tailscale coordination server URL.
TS_LOGIN_SERVER=https://vpn.mass-hysteria.org
# TS_AUTHKEY: pre-auth key for unattended node registration (optional).
# Generate one in the Headscale admin UI or `headscale preauthkeys create`.
# Leave blank to authorize interactively via the login URL printed at setup.
TS_AUTHKEY=
