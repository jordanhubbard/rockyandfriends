# RCC Agent — Environment Template
# Copy to ~/.rcc/.env and fill in your values. NEVER commit .env to git.
#
#   cp deploy/.env.template ~/.rcc/.env && nano ~/.rcc/.env
#
# This file is for CLIENT AGENTS connecting to an existing RCC hub.
# If you are standing up a new RCC hub, also see deploy/.env.server.template.

# ── RCC Connection ─────────────────────────────────────────────────────────
# The URL and token for your RCC hub — provided by your RCC admin at onboarding
RCC_URL=
RCC_AGENT_TOKEN=

# ── Agent Identity ─────────────────────────────────────────────────────────
# Short name for this agent (e.g. bullwinkle, natasha, boris, or your own name)
AGENT_NAME=
# Human-readable hostname shown in the dashboard
AGENT_HOST=

# ── Agent Capabilities ────────────────────────────────────────────────────
# Declare what this node can do so the RCC hub can route work to you correctly
AGENT_CLAUDE_CLI=false
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
AGENT_HAS_GPU=false
AGENT_GPU_MODEL=
AGENT_GPU_COUNT=0
AGENT_GPU_VRAM_GB=0

# ── NVIDIA Inference ──────────────────────────────────────────────────────
# Your personal API key for the NVIDIA inference gateway
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=

# ── Milvus Vector DB (for RAG / ingest-memory.mjs) ───────────────────────
# Point at the do-host1 Milvus instance (Tailscale IP — must be on VPN)
# Rocky (do-host1): localhost:19530
# All other agents: 100.89.199.14:19530
MILVUS_ADDRESS=100.89.199.14:19530
EMBED_MODEL=azure/openai/text-embedding-3-large
EMBED_DIM=3072

# ── Messaging ─────────────────────────────────────────────────────────────
# Mattermost: get a personal access token from your Mattermost instance
MATTERMOST_TOKEN=
MATTERMOST_URL=

# Telegram: optional direct bot channel
TELEGRAM_TOKEN=

# Slack: agents use the RCC hub as a proxy — no per-agent Slack app needed.
# To post to Slack, call: POST $RCC_URL/api/slack/send
#   {"text": "...", "channel": "C...", "as_agent": "yourname"}
# The hub posts on your behalf with your configured username/emoji.
# Leave SLACK_TOKEN blank unless you ARE the RCC hub.
SLACK_TOKEN=
# Signing secret from Slack App settings — required for inbound event verification.
# Get it from https://api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=
