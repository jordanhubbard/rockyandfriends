<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.acc.exec-listen</string>

    <key>ProgramArguments</key>
    <array>
        <string>AGENT_HOME/.acc/bin/acc-agent</string>
        <string>listen</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>AGENT_HOME/.acc/logs/exec-listen.log</string>
    <key>StandardErrorPath</key>
    <string>AGENT_HOME/.acc/logs/exec-listen.log</string>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
