[Unit]
Description=ACC Hub Server
Documentation=https://github.com/{OWNER}/ACC
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=AGENT_USER
WorkingDirectory=AGENT_HOME/.acc

ExecStart=/usr/local/bin/acc-server

# Core config
Environment=ACC_PORT=8789
Environment=ACC_DATA_DIR=AGENT_HOME/.acc/data
Environment=RUST_LOG=acc_server=info

# Include ~/.acc/bin on PATH so the supervisor can spawn acc-agent subprocesses
Environment=PATH=AGENT_HOME/.acc/bin:/usr/local/bin:/usr/bin:/bin

# Load per-node secrets (tokens, LLM keys, etc.)
EnvironmentFile=-AGENT_HOME/.acc/.env

# Restart on crash only — not on clean exits
Restart=on-failure
RestartSec=5s
TimeoutStopSec=15

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=acc-server

[Install]
WantedBy=multi-user.target
