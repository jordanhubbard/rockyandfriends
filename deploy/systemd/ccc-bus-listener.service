[Unit]
Description=CCC Bus Listener (ClawBus SSE daemon)
Documentation=https://github.com/jordanhubbard/CCC
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=AGENT_USER
EnvironmentFile=-AGENT_HOME/.ccc/.env
Environment=PATH=AGENT_HOME/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/bin/bash AGENT_HOME/.ccc/workspace/deploy/bus-listener.sh
Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
