{
  "_comment": "Default ACC command registry. Installed to ~/.acc/commands.json. Add site-specific commands there; do not edit this file — it will be overwritten on agent-pull.",
  "commands": [
    {
      "name": "ping",
      "description": "Echo a message back — connectivity check",
      "program": "echo",
      "args": ["pong: {message}"],
      "params": {
        "message": {
          "type": "string",
          "max_len": 256,
          "default": "ok"
        }
      }
    },
    {
      "name": "log_tail",
      "description": "Return the last N lines of a named agent log",
      "program": "tail",
      "args": ["-n", "{lines}", "{ACC_DIR}/logs/{log}.log"],
      "params": {
        "lines": {
          "type": "integer",
          "min": 1,
          "max": 1000,
          "default": 100
        },
        "log": {
          "type": "enum",
          "values": [
            "bus-listener",
            "queue-worker",
            "hermes-worker",
            "hermes-driver",
            "acc-agent",
            "exec-listen"
          ]
        }
      }
    },
    {
      "name": "update",
      "description": "Pull latest workspace code (agent-pull.sh)",
      "program": "bash",
      "args": ["{ACC_DIR}/workspace/deploy/agent-pull.sh"],
      "params": {},
      "timeout_secs": 180
    },
    {
      "name": "restart_service",
      "description": "Restart a named ACC service (Linux systemd)",
      "program": "systemctl",
      "args": ["restart", "{service}"],
      "params": {
        "service": {
          "type": "enum",
          "values": [
            "acc-bus-listener",
            "acc-queue-worker",
            "acc-hermes-worker",
            "acc-server",
            "acc-task-worker"
          ]
        }
      },
      "platforms": ["linux"]
    },
    {
      "name": "service_status",
      "description": "Check status of a named ACC service (Linux systemd)",
      "program": "systemctl",
      "args": ["status", "--no-pager", "{service}"],
      "params": {
        "service": {
          "type": "enum",
          "values": [
            "acc-bus-listener",
            "acc-queue-worker",
            "acc-hermes-worker",
            "acc-server",
            "acc-task-worker"
          ]
        }
      },
      "platforms": ["linux"]
    },
    {
      "name": "disk_usage",
      "description": "Report disk usage on agent home directory",
      "program": "df",
      "args": ["-h", "{ACC_DIR}"],
      "params": {}
    },
    {
      "name": "hermes_sessions",
      "description": "List active hermes sessions",
      "program": "hermes",
      "args": ["session", "list"],
      "params": {},
      "timeout_secs": 10
    },
    {
      "name": "queue_status",
      "description": "Show queue worker process status",
      "program": "pgrep",
      "args": ["-a", "-f", "acc-agent queue"],
      "params": {}
    }
  ]
}
