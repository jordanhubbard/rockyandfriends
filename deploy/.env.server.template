# RCC Hub Server — Environment Template
# This file is for the node running the RCC API server (the hub).
# Client agents only need deploy/.env.template.
#
#   cp deploy/.env.server.template ~/.rcc/.env && nano ~/.rcc/.env

# ── RCC API Server ────────────────────────────────────────────────────────
# Port the RCC API listens on
RCC_PORT=8789
# Comma-separated list of valid Bearer tokens accepted by this server.
# Generate one per agent with: openssl rand -hex 16
RCC_AUTH_TOKENS=

# ── Hub Agent Identity ────────────────────────────────────────────────────
AGENT_NAME=rocky
AGENT_HOST=
RCC_AGENT_TOKEN=  # hub's own token (one of the values in RCC_AUTH_TOKENS)

# ── Object Storage: MinIO ─────────────────────────────────────────────────
# Internal S3-compatible storage for agent state, heartbeats, shared assets.
# MinIO is an internal implementation detail — client agents never touch this.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=agents
MINIO_ALIAS=rcc-hub

# ── Public Asset Storage: Azure Blob (or compatible) ─────────────────────
# For publicly readable files (images, reports, etc.)
AZURE_BLOB_PUBLIC_URL=
AZURE_BLOB_SAS_TOKEN=

# ── Slack App (hub-level — proxied to all agents) ─────────────────────────
# The hub holds ONE Slack app token with chat:write.customize scope.
# Agents call POST /api/slack/send and the hub posts on their behalf.
# See: https://api.slack.com/methods/chat.postMessage
SLACK_TOKEN=
# Default workspace channel for agent announcements (optional)
SLACK_DEFAULT_CHANNEL=

# ── Mattermost ────────────────────────────────────────────────────────────
MATTERMOST_TOKEN=
MATTERMOST_URL=

# ── GitHub Scout ──────────────────────────────────────────────────────────
# For the repo scanner (rcc/scout/) — watches repos for issues/CI failures
GITHUB_TOKEN=
WATCH_CHANNEL=  # Slack channel ID for scout notifications

# ── NVIDIA Inference ──────────────────────────────────────────────────────
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=
