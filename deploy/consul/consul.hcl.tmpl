# consul.hcl.tmpl — unified Consul config template for CCC fleet nodes
#
# Rendered by deploy/migrations/0009_install_consul.sh into ~/.ccc/consul/consul.hcl
# using ##PLACEHOLDER## substitutions resolved at install time.
#
# DO NOT use Consul's own {{ GetInterfaceIP "..." }} go-template syntax here —
# it fails on macOS and is unnecessary since we resolve the IP at migration time.

datacenter = "ccc"
node_name  = "##AGENT_NAME##"
server     = ##IS_SERVER##

##BOOTSTRAP_LINE##

# Tailscale IP resolved at install time (not runtime go-template)
bind_addr   = "##BIND_ADDR##"
client_addr = "127.0.0.1"

# CCC-owned paths — never system-wide directories
data_dir = "##DATA_DIR##"

# Service definitions copied here from deploy/consul/service-defs/##AGENT_NAME##.hcl
services_dir = "##SERVICES_DIR##"

##RETRY_JOIN_LINE##

ports {
  dns  = 8600
  http = 8500
  grpc = 8502
}

dns_config {
  allow_stale = true
}

# UI enabled on hub (server) nodes for debugging
ui_config {
  enabled = ##UI_ENABLED##
}

enable_local_script_checks = true
disable_remote_exec         = true
log_level                   = "INFO"

telemetry {
  disable_hostname          = true
  prometheus_retention_time = "24h"
}
