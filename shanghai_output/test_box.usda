#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "World"
{
    def Mesh "Box" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-50, 0, -50), (50, 100, 50)]
        int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
        int[] faceVertexIndices = [0,1,2,3, 7,6,5,4, 0,1,5,4, 1,2,6,5, 2,3,7,6, 3,0,4,7]
        point3f[] points = [(-50,0,-50),(50,0,-50),(50,0,50),(-50,0,50),(-50,100,-50),(50,100,-50),(50,100,50),(-50,100,50)]
        rel material:binding = </World/Mats/BoxMat>
    }

    def Xform "Mats"
    {
        def Material "BoxMat"
        {
            token outputs:mdl:surface.connect = </World/Mats/BoxMat/S.outputs:out>
            def Shader "S"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                color3f inputs:diffuse_color_constant = (0.2, 0.5, 0.9)
                float inputs:metallic_constant = 0.3
                float inputs:reflection_roughness_constant = 0.2
                token outputs:out
            }
        }
    }

    def DistantLight "Sun" (prepend apiSchemas = ["ShapingAPI"])
    {
        float inputs:intensity = 3000
        float3 xformOp:rotateXYZ = (-45, 30, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }
    def DomeLight "Sky" (prepend apiSchemas = ["ShapingAPI"])
    {
        float inputs:intensity = 800
        float inputs:shaping:cone:angle = 180
    }
}

def Camera "Cam"
{
    float2 clippingRange = (0.1, 10000)
    float focalLength = 18.147562
    float horizontalAperture = 20.955
    float verticalAperture = 15.2908
    float3 xformOp:rotateYXZ = (-25, 45, 0)
    float3 xformOp:scale = (1,1,1)
    double3 xformOp:translate = (300, 200, 300)
    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateYXZ", "xformOp:scale"]
}

def "Render" (hide_in_stage_window = true no_delete = true)
{
    def "OmniverseKit"
    {
        def "HydraTextures" (hide_in_stage_window = true no_delete = true)
        {
            def RenderProduct "VP" (hide_in_stage_window = true no_delete = true)
            {
                rel camera = </Cam>
                token omni:rtx:background:source:type = "sky"
                rel orderedVars = </Render/Vars/LdrColor>
                uniform int2 resolution = (1280, 720)
            }
        }
    }
    def RenderSettings "Settings" (no_delete = true)
    {
        rel products = [</Render/OmniverseKit/HydraTextures/VP>]
    }
    def "Vars"
    {
        def RenderVar "LdrColor" (hide_in_stage_window = true no_delete = true)
        {
            uniform string sourceName = "LdrColor"
        }
    }
}
