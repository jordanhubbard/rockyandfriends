{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "agentOS PD health — VibeEngine slots, GPU scheduler, watchdog, agent pool (sparky/GB10)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "VibeEngine WASM Slots",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Idle" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["last"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "agentos_vibe_slots_active{host=\"sparky\"}", "legendFormat": "Active", "refId": "A" },
        { "expr": "agentos_vibe_slots_idle{host=\"sparky\"}", "legendFormat": "Idle", "refId": "B" },
        { "expr": "agentos_vibe_slots_total{host=\"sparky\"}", "legendFormat": "Total Capacity", "refId": "C" }
      ],
      "title": "VibeEngine Slot Utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 4 }
          ]},
          "max": 4, "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "expr": "agentos_vibe_slots_active{host=\"sparky\"}", "legendFormat": "Active Slots", "refId": "A" }
      ],
      "title": "Active Slots (now)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 }
          ]},
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "All OK" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "agentos_watchdog_miss_total{host=\"sparky\"}", "legendFormat": "Watchdog Misses", "refId": "A" }
      ],
      "title": "Watchdog Miss Total",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 11,
      "title": "GPU Scheduler & Agent Pool",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "agentos_gpu_queue_depth{host=\"sparky\"}", "legendFormat": "GPU Queue Depth", "refId": "A" }
      ],
      "title": "GPU Scheduler Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "In Use" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": { "legend": { "calcs": ["last"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "agentos_agent_pool_available{host=\"sparky\"}", "legendFormat": "Available", "refId": "A" },
        { "expr": "agentos_agent_pool_total{host=\"sparky\"} - agentos_agent_pool_available{host=\"sparky\"}", "legendFormat": "In Use", "refId": "B" },
        { "expr": "agentos_agent_pool_total{host=\"sparky\"}", "legendFormat": "Total Capacity", "refId": "C" }
      ],
      "title": "Agent Pool Utilization",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 12,
      "title": "Watchdog",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 6,
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "increase(agentos_watchdog_miss_total{host=\"sparky\"}[5m])", "legendFormat": "Miss Rate (5m)", "refId": "A" },
        { "expr": "agentos_watchdog_miss_total{host=\"sparky\"}", "legendFormat": "Total Misses (cumulative)", "refId": "B" }
      ],
      "title": "Watchdog Miss Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["agentOS", "sparky", "seL4"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "agentOS PD Health (sparky)",
  "uid": "agentos-pd-health-sparky",
  "version": 1
}
